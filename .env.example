# ============================================
# 安居客房源爬虫 - 环境变量配置示例
# ============================================

# ------------------------
# 数据库配置
# ------------------------
DB_HOST=localhost           # 数据库主机地址
DB_USER=root                # 数据库用户名
DB_PWD=your_password        # 数据库密码（必填）
DB_NAME=your_db_name    # 数据库名称（需预先创建）
DB_CHARSET=utf8mb4          # 数据库字符集

# ------------------------
# 请求头配置
# ------------------------
USER_AGENT=      # 留空则使用默认浏览器标识，如需自定义可填写自己的UA
COOKIE=                     # Cookie（留空则以游客身份访问，完整数据需要填写）

# ------------------------
# 爬虫配置
# ------------------------
REQUEST_TIMEOUT=10          # 请求超时时间（秒）
REQUEST_DELAY=0.8           # 请求间隔（秒），建议 >= 0.5
MAX_RETRIES=3              # 最大重试次数